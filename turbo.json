{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": [".env"],
      "env": ["AURA_AUTH_*"],
      "outputs": [
        "dist/**",
        "!.turbo/**",
        ".next/**",
        "!.next/cache/**",
        ".tanstack/**",
        ".output/**",
        ".react-router/**",
        ".nuxt/**",
        ".astro/**",
        ".wrangler/**",
        ".vercel/output/**"
      ]
    },
    "@aura-stack/react#build": {
      "dependsOn": ["@aura-stack/auth#build"]
    },
    "@aura-stack/react-router#build": {
      "dependsOn": ["@aura-stack/react#build"]
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false
    },
    "format": {
      "dependsOn": ["^format"],
      "outputLogs": "new-only"
    },
    "//#format:root": {
      "outputLogs": "new-only"
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputLogs": "new-only",
      "persistent": false
    }
  },
  "ui": "stream",
  "cacheDir": ".turbo/cache",
  "globalDependencies": [".env", "tsconfig.json"],
  "globalEnv": [".env"],
  "remoteCache": {
    "enabled": true,
    "signature": false
  }
}
