{
  "name": "@aura-stack/auth-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "An open-source authentication library for TypeScript.",
  "scripts": {
    "dev": "turbo run dev",
    "dev:core": "turbo run @aura-stack/auth#dev",
    "dev:docs": "turbo run docs#dev",
    "build": "turbo run build --filter=./configs/* --filter=./packages/* --filter=./apps/*",
    "build:packages": "turbo run build --filter=./configs/* --filter=./packages/* --filter=!./packages/integration --continue=dependencies-successful",
    "test": "turbo run test --parallel --filter=./packages/* --filter=!./packages/integration",
    "format": "turbo run format format:root --parallel",
    "format:root": "oxfmt \"!packages\" \"!apps\" \"!configs\"",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "type-check": "turbo run type-check --parallel",
    "type-check:packages": "turbo run type-check --parallel --filter=./packages/*",
    "create:integration": "node packages/shared/scripts/integration.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aura-stack-js/auth.git"
  },
  "bugs": "https://github.com/aura-stack-js/auth/issues",
  "homepage": "https://github.com/aura-stack-js/auth#readme",
  "keywords": [
    "authentication",
    "auth",
    "library",
    "javascript",
    "typescript",
    "oauth 2.0",
    "openid connect",
    "oidc"
  ],
  "author": "Aura Stack <aurastackjs@gmail.com> | Hernan Alvarado <halvaradop.dev@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "catalog:node",
    "@vitest/coverage-v8": "catalog:vitest",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.18",
    "typescript": "catalog:typescript",
    "vitest": "catalog:vitest"
  },
  "packageManager": "pnpm@10.15.0",
  "workspaces": {
    "packages": [
      "packages/*",
      "configs/*",
      "apps/**",
      "docs"
    ],
    "catalogs": {
      "@tailwindcss/vite": {
        "@tailwindcss/vite": "^4.0.6"
      },
      "lucide-react": {
        "lucide-react": "^0.561.0"
      },
      "next": {
        "next": "^16.2.6"
      },
      "node": {
        "@types/node": "^24.9.2"
      },
      "react": {
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
      },
      "tailwindcss": {
        "@tailwindcss/postcss": "^4.1.16",
        "tailwindcss": "4.1.18"
      },
      "typescript": {
        "typescript": "^5.9.2"
      },
      "vite": {
        "vite": "^7.3.2"
      },
      "zod-v3": {
        "zod": "3.25.76"
      },
      "zod-v4": {
        "zod": "4.3.5"
      },
      "hono": {
        "hono": "4.12.21"
      },
      "bun": {
        "@types/bun": "^1.3.9"
      },
      "express": {
        "@types/express": "^4.17.17",
        "express": "^4.18.2"
      },
      "react-router": {
        "react-router": "7.15.0"
      },
      "vitest": {
        "vitest": "4.1.4",
        "@vitest/coverage-v8": "4.1.4"
      },
      "valibot": {
        "valibot": "^1.4.0"
      },
      "testing-library": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1"
      }
    }
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "file-type": "^21.3.2",
    "undici": "^7.24.0",
    "seroval": "^1.4.1",
    "lodash": "^4.18.0",
    "lodash-es": "^4.18.0",
    "tar": "^7.5.11",
    "path-to-regexp": "^1.9.0",
    "serialize-javascript": "^7.0.3",
    "h3": "^2.0.1-rc.17",
    "brace-expansion": "^5.0.6",
    "uuid": "^11.1.1",
    "qs": "^6.15.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.69.0"
  }
}
