{
  "name": "@aura-stack/auth-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "An open-source authentication library for TypeScript.",
  "scripts": {
    "dev": "turbo run dev",
    "dev:core": "turbo run @aura-stack/auth#dev",
    "dev:docs": "turbo run docs#dev",
    "build": "turbo run build --filter=./configs/* --filter=./packages/* --filter=./apps/*",
    "build:prod": "turbo run build --filter=./configs/* --filter=./packages/* --continue=dependencies-successful",
    "test": "turbo run test --parallel",
    "format": "turbo run format format:root --parallel",
    "format:root": "oxfmt \"!packages\" \"!apps\" \"!configs\"",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "type-check": "turbo run type-check --parallel"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aura-stack-js/auth.git"
  },
  "bugs": "https://github.com/aura-stack-js/auth/issues",
  "homepage": "https://github.com/aura-stack-js/auth#readme",
  "keywords": [
    "authentication",
    "auth",
    "library",
    "javascript",
    "typescript",
    "oauth 2.0",
    "openid connect",
    "oidc"
  ],
  "author": "Aura Stack <aurastackjs@gmail.com> | Hernan Alvarado <halvaradop.dev@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "catalog:node",
    "@vitest/coverage-v8": "^4.0.14",
    "eslint": "^9.35.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsdown": "^0.21.8",
    "tsup": "^8.5.1",
    "turbo": "^2.7.5",
    "typescript": "catalog:typescript",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.15.0",
  "workspaces": {
    "packages": [
      "packages/*",
      "configs/*",
      "apps/**",
      "docs"
    ],
    "catalogs": {
      "@tailwindcss/vite": {
        "@tailwindcss/vite": "^4.0.6"
      },
      "lucide-react": {
        "lucide-react": "^0.561.0"
      },
      "next": {
        "next": "^16.1.6"
      },
      "node": {
        "@types/node": "^24.9.2"
      },
      "react": {
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
      },
      "tailwindcss": {
        "@tailwindcss/postcss": "^4.1.16",
        "tailwindcss": "4.1.18"
      },
      "typescript": {
        "typescript": "^5.9.2"
      },
      "vite": {
        "vite": "^7.1.7"
      },
      "zod-v3": {
        "zod": "3.25.76"
      },
      "zod-v4": {
        "zod": "4.3.5"
      },
      "hono": {
        "hono": "4.12.8"
      },
      "bun": {
        "@types/bun": "^1.3.9"
      },
      "express": {
        "@types/express": "^4.17.17",
        "express": "^4.18.2"
      },
      "react-router": {
        "react-router": "7.12.0"
      }
    }
  },
  "overrides": {
    "dompurify": "^3.3.2",
    "file-type": "^21.3.2",
    "undici": "^7.24.0",
    "seroval": "^1.4.1",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "tar": "^7.5.11",
    "path-to-regexp": "^1.9.0",
    "serialize-javascript": "^7.0.3"
  }
}
