{
    "extends": "@aura-stack/tsconfig/bun.json",
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
            "@test/*": ["./test/*"],
        },
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
    },
    "include": ["src", "test"],
    "exclude": ["dist", "node_modules"],
}
