{
  "extends": "@aura-stack/tsconfig/bun.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./test/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsxImportSource": "hono/jsx"
  },
  "include": ["src", "test"],
  "exclude": ["dist", "node_modules"]
}
