{
  "extends": ["@aura-stack/tsconfig/tsconfig.base.json"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src", "!src/client/client.ts", "!src/client/index.ts"],
  "exclude": ["node_modules", "dist", "test", "coverage", "dist", "src/client/client.ts", "src/client/index.ts"]
}
