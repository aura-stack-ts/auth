{
  "extends": ["@aura-stack/tsconfig/tsconfig.base.json"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test", "coverage", "dist"]
}
